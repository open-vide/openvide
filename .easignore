# macOS
.DS_Store

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editor / local
.idea/
.vscode/
*.swp
*.swo

# docs/build artifacts
docs/.vitepress/dist/
docs/node_modules/

# Expo / React Native app
node_modules/
.expo/
.expo-shared/
.turbo/
dist/
web-build/

# Metro / React Native temp
.metro-health-check*
.tmp/
tmp/

# Yarn 4 (keep release/plugins if present)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# native build outputs (generated by expo prebuild)
apps/app/android/
apps/app/ios/

# NOTE: Unlike .gitignore, EAS builds NEED these files:
# - apps/app/app.json (EAS project link)
# - apps/app/google-services.json (Firebase config)
# - apps/app/variants/*/config.json (variant configs)
# - apps/app/variants/*/*.png (icons and splash assets)
# - apps/app/variants/*/splash-animation.json (Lottie animations)
# So they are NOT listed here.
