# macOS
.DS_Store

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files
.env
.env.*
!.env.example
!.env.*.example

# editor / local
.idea/
.vscode/
*.swp
*.swo

# docs/build artifacts
docs/.vitepress/dist/
docs/node_modules/

# Expo / React Native app
node_modules/
.expo/
.expo-shared/
.turbo/
dist/
web-build/

# Metro / React Native temp
.metro-health-check*
.tmp/
tmp/

# Yarn 4 (keep release/plugins if present)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# native build outputs (generated by expo prebuild)
apps/app/android/
apps/app/ios/

# EAS project link (created by `eas init`, contains personal project ID)
apps/app/app.json

# Firebase config (contains project-specific keys)
apps/app/google-services.json

# Google Play service account key (for EAS Submit)
apps/app/google-play-service-account.json

# Android keystore
*.jks
*.keystore

# App variant configs & assets (contain personal bundle IDs / branded assets)
# Copy the *.example.json files and fill in your own values
apps/app/variants/*/config.json
apps/app/variants/*/*.png
apps/app/variants/*/splash-animation.json
