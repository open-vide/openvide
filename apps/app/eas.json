{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "env": { "APP_VARIANT": "development", "COREPACK_ENABLE_STRICT": "0" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": { "APP_VARIANT": "production", "COREPACK_ENABLE_STRICT": "0" }
    },
    "production": {
      "channel": "production",
      "env": { "APP_VARIANT": "production", "COREPACK_ENABLE_STRICT": "0" }
    },
    "production:apk": {
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": { "APP_VARIANT": "production", "COREPACK_ENABLE_STRICT": "0" }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
