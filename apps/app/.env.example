# Apple Development Team ID (required for iOS builds)
APP_DEVELOPMENT_TEAM=

# EAS project ID (fallback if app.json is not present)
# Get this from `eas init` or your Expo dashboard
EXPO_PROJECT_ID=

# Set to "1" to enable push notifications (requires paid Apple Developer account
# for iOS and google-services.json for Android). Leave unset or empty to disable —
# the app will still build and work, just without push notifications.
# ENABLE_PUSH_NOTIFICATIONS=1
