# Developer-specific settings (not variant-specific)
# Copy this to .env and fill in your values.
APP_DEVELOPMENT_TEAM=YOUR_TEAM_ID

# Bundle IDs, display names, and schemes are defined per variant in:
#   variants/production/config.json
#   variants/development/config.json
#
# To build the dev variant, use the :dev script variants:
#   yarn prebuild:dev:clean   — generate native projects with dev bundle IDs
#   yarn ios:dev:install      — build and install dev variant on iOS
#   yarn android:dev          — build and install dev variant on Android
#   yarn start:dev            — start Metro for dev variant
