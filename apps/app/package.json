{
  "name": "@openvide/app",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "APP_VARIANT=development expo start",
    "android": "expo run:android",
    "android:dev": "APP_VARIANT=development expo run:android",
    "ios": "node scripts/cleanup-stale-ios-projects.js && expo run:ios --scheme OpenVide --no-install",
    "ios:install": "node scripts/cleanup-stale-ios-projects.js && expo run:ios --scheme OpenVide",
    "ios:dev": "APP_VARIANT=development node scripts/cleanup-stale-ios-projects.js && APP_VARIANT=development expo run:ios --scheme OpenVide --no-install",
    "ios:dev:install": "APP_VARIANT=development node scripts/cleanup-stale-ios-projects.js && APP_VARIANT=development expo run:ios --scheme OpenVide",
    "prebuild": "expo prebuild && [ \"$ENABLE_PUSH_NOTIFICATIONS\" = \"1\" ] || node scripts/strip-push-entitlement.js",
    "prebuild:clean": "expo prebuild --clean && [ \"$ENABLE_PUSH_NOTIFICATIONS\" = \"1\" ] || node scripts/strip-push-entitlement.js",
    "prebuild:dev": "APP_VARIANT=development expo prebuild && [ \"$ENABLE_PUSH_NOTIFICATIONS\" = \"1\" ] || node scripts/strip-push-entitlement.js",
    "prebuild:dev:clean": "APP_VARIANT=development expo prebuild --clean && [ \"$ENABLE_PUSH_NOTIFICATIONS\" = \"1\" ] || node scripts/strip-push-entitlement.js",
    "web": "expo start --web",
    "check": "tsc --noEmit",
    "dev": "expo start",
    "build:dev": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:local": "eas build --profile development --platform android --local",
    "build:dev:ios:local": "eas build --profile development --platform ios --local",
    "build:preview": "eas build --profile preview --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:prod": "eas build --profile production --platform android",
    "build:prod:ios": "eas build --profile production --platform ios",
    "build:prod:local": "eas build --profile production --platform android --local",
    "build:prod:ios:local": "eas build --profile production --platform ios --local",
    "build:all": "eas build --profile production --platform all",
    "update:dev": "eas update --channel development",
    "update:preview": "eas update --channel preview",
    "update:prod": "eas update --channel production"
  },
  "dependencies": {
    "@dylankenneally/react-native-ssh-sftp": "^1.5.20",
    "@jamsch/expo-speech-recognition": "^0.2.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.0.15",
    "@react-navigation/native-stack": "^7.3.0",
    "clsx": "^2.1.0",
    "expo": "^54.0.33",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-glass-effect": "~0.1.9",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-updates": "~29.0.16",
    "lottie-react-native": "~7.3.1",
    "nativewind": "4.2.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@types/react": "~19.1.10",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}
